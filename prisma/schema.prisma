generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Otp {
  id        Int      @id @default(autoincrement())
  phone     String
  otp       String
  purpose   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([otp])
  @@map("otps")
}

model User {
  id                             Int                       @id @default(autoincrement())
  full_name                      String
  role_id                        Int
  username                       String                    @unique
  password_hash                  String?
  email                          String?                   @unique
  cnic                           String?
  phone                          String?
  device_id                      String?
  status                         String                    @default("active")
  created_at                     DateTime                  @default(now())
  updated_at                     DateTime                  @updatedAt
  bio                            String?                   @db.Text
  image                          String?                   @db.VarChar(255)
  coverImage                     String?                   @db.VarChar(255)
  permissions_json               Json?
  fcm_token                      String?                   @db.VarChar(255)
  reset_token_expires            DateTime?
  reset_token_hash               String?
  bike_km_range                  Int?
  is_online                      Boolean                   @default(false)
  last_known_latitude            Float?
  last_known_longitude           Float?
  last_online_at                 DateTime?
  working_hours_end              String?                   @db.VarChar(30)
  working_hours_start            String?                   @db.VarChar(30)
  outlet_id                      Int?
  officer_profile_history        Json?
  current_active_verification_id Int?                      @unique
  deliveries                     Delivery[]                @relation("delivery_agent")
  officerAssignments             OfficerAreaAssignment[]   @relation("OfficerAssignments")
  officerSessions                OfficerSession[]
  assigned_orders                Order[]                   @relation("assignedOrders")
  created_orders                 Order[]
  delivery_orders                Order[]                   @relation("deliveryOrders")
  recovery_orders                Order[]                   @relation("recoveryOrders")
  product_change_histories       OrderProductHistory[]     @relation("ProductChangeHistory")
  current_active_verification    Verification?             @relation("active_verification", fields: [current_active_verification_id], references: [id])
  outlet                         Outlet?                   @relation(fields: [outlet_id], references: [id])
  role                           Role                      @relation(fields: [role_id], references: [id])
  verifications                  Verification[]            @relation("verification_officer")
  verification_reviews           VerificationReview[]      @relation("verification_reviewer")
  cash_in_hand                   CashInHand[]              @relation("OfficerCashInHand")
  assigned_complaints            Complaint[]               @relation("assignedComplaints")
  created_complaints             Complaint[]               @relation("createdComplaints")
  notifications                  Notification[]
  otp_logs                       OtpLog[]
  recovery_visits                RecoveryVisit[]           @relation("OfficerRecoveryVisit")
  return_exchanges               ReturnExchange[]          @relation("OfficerReturnExchange")
  security_logs                  SecurityLog[]
  verification_edit_history      VerificationEditHistory[] @relation("user_edits")
  vendor_purchase_edits          VendorPurchaseEditHistory[] @relation("vendor_purchase_edits")
  collected_payments             OrderPayment[]            @relation("PaymentCollector")
  status_changes                 OrderStatusHistory[]      @relation("UserOrderStatusChanges")
  csr_rankings                   CsrRanking[]

  @@index([role_id])
  @@index([is_online])
  @@index([role_id, is_online])
  @@index([last_online_at])
  @@index([outlet_id])
}

model Role {
  id               Int     @id @default(autoincrement())
  name             String
  permissions_json Json?
  users            User[]
}

model Order {
  id                       Int                   @id @default(autoincrement())
  order_ref                String                @unique
  token_number             String                @unique
  customer_name            String
  whatsapp_number          String
  address                  String
  city                     String?
  area                     String?
  product_name             String
  total_amount             Float
  advance_amount           Float
  monthly_amount           Float
  months                   Int
  channel                  String
  status                   String                @default("new")
  created_at               DateTime              @default(now())
  updated_at               DateTime              @default(now())
  created_by_user_id       Int?
  assigned_to_user_id      Int?
  delivery_officer_id      Int?
  is_delivered             Boolean               @default(false)
  otp_expires_at           DateTime?
  otp_generated_at         DateTime?
  pickup_otp               String?               @db.VarChar(5)
  gender                   String?
  marital_status           String?
  residential_type         String?
  block                    String?
  house_no                 String?
  street                   String?
  zone                     String?
  cancelled_at             DateTime?
  cancelled_reason         String?               @db.Text
  recovery_officer_id      Int?
  outlet_id                Int?
  alternate_contact        String?
  order_notes              String?               @db.Text
  imei_serial              String?
  postponed_feedback       String?               @db.Text
  delivery_assigned_at     DateTime?
  recovery_assigned_at     DateTime?
  verification_assigned_at DateTime?
  dummyCustomer            DummyCustomer?        @relation("OrderDummyCustomer")
  delivery                 Delivery?             @relation("OrderDelivery")
  assigned_to              User?                 @relation("assignedOrders", fields: [assigned_to_user_id], references: [id])
  created_by               User?                 @relation(fields: [created_by_user_id], references: [id])
  delivery_officer         User?                 @relation("deliveryOrders", fields: [delivery_officer_id], references: [id])
  outlet                   Outlet?               @relation(fields: [outlet_id], references: [id])
  recovery_officer         User?                 @relation("recoveryOrders", fields: [recovery_officer_id], references: [id])
  customer_id              Int?
  is_repeat_customer       Boolean               @default(false)
  customer                 Customer?             @relation(fields: [customer_id], references: [id])
  payments                 OrderPayment[]
  productHistories         OrderProductHistory[]
  verification             Verification?         @relation("OrderVerification")
  cash_in_hand             CashInHand[]          @relation("OrderCashInHand")
  installment_ledger       InstallmentLedger?
  recovery_visits          RecoveryVisit[]       @relation("OrderRecoveryVisit")
  return_exchanges         ReturnExchange[]      @relation("OrderReturnExchange")
  smart_pay_qrs            SmartPayQr[]
  statusHistories          OrderStatusHistory[]  @relation("OrderStatusHistoryLogs")

  @@index([created_by_user_id])
  @@index([assigned_to_user_id])
  @@index([delivery_officer_id])
  @@index([recovery_officer_id])
  @@index([outlet_id])
  @@index([imei_serial])
}

model OrderStatusHistory {
  id         Int      @id @default(autoincrement())
  order_id   Int
  old_status String?
  new_status String
  user_id    Int?
  role_name  String?
  remarks    String?  @db.Text
  created_at DateTime @default(now())

  order      Order    @relation("OrderStatusHistoryLogs", fields: [order_id], references: [id], onDelete: Cascade)
  user       User?    @relation("UserOrderStatusChanges", fields: [user_id], references: [id])

  @@index([order_id])
  @@index([user_id])
  @@map("order_status_histories")
}

model DummyCustomer {
  id                 Int      @id @default(autoincrement())
  order_id           Int      @unique
  customer_name      String?
  whatsapp_number    String?
  address            String?
  city               String?
  area               String?
  block              String?
  house_no           String?
  street             String?
  zone               String?
  alternate_contact  String?
  moved_at           DateTime @default(now())

  order              Order    @relation("OrderDummyCustomer", fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@map("dummy_customers")
}

model Complaint {
  id                  Int      @id @default(autoincrement())
  complaint_id        String   @unique
  customer_name       String
  customer_cnic       String?
  mobile_number       String
  description         String   @db.Text
  status              String   @default("New")
  resolution_note     String?  @db.Text
  created_by_user_id  Int?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  assigned_to_user_id Int?
  media_urls          Json?
  assigned_to         User?    @relation("assignedComplaints", fields: [assigned_to_user_id], references: [id])
  created_by          User?    @relation("createdComplaints", fields: [created_by_user_id], references: [id])

  @@index([mobile_number])
  @@index([status])
  @@index([assigned_to_user_id])
  @@index([created_by_user_id], map: "complaints_created_by_user_id_fkey")
  @@map("complaints")
}

model Outlet {
  id               Int               @id @default(autoincrement())
  code             String            @unique
  name             String
  address          String?
  status           String            @default("active")
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  orders           Order[]
  users            User[]
  cash_in_hand     CashInHand[]      @relation("OutletCashInHand")
  cashRegisters    CashRegister[]
  expenseVouchers  ExpenseVoucher[]
  inventories      OutletInventory[]
  return_exchanges ReturnExchange[]  @relation("OutletReturnExchange")
  security_logs    SecurityLog[]
  vendorPayments   VendorPayment[]
  vendorPurchases  VendorPurchase[]
  vendorPurchaseReturns VendorPurchaseReturn[]
  vendors          Vendor[]
  auto_assignment_config Json?

  @@map("outlets")
}

model CashRegister {
  id                    Int      @id @default(autoincrement())
  outlet_id             Int
  date                  DateTime
  opening_cash          Float    @default(0)
  down_payments         Float    @default(0)
  installments_received Float    @default(0)
  cash_from_recovery    Float    @default(0)
  cash_from_delivery    Float    @default(0)
  expenses              Float    @default(0)
  closing_cash          Float    @default(0)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  vendor_payments       Float    @default(0)
  outlet                Outlet   @relation(fields: [outlet_id], references: [id], onDelete: Cascade)

  @@unique([outlet_id, date])
  @@index([outlet_id])
  @@index([date])
  @@map("cash_registers")
}

model ExpenseVoucher {
  id             Int           @id @default(autoincrement())
  outlet_id      Int
  voucher_number String        @unique
  total_amount   Float         @default(0)
  payment_method String        @default("Cash")
  date           DateTime      @default(now())
  notes          String?       @db.Text
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  items          ExpenseItem[]
  outlet         Outlet        @relation(fields: [outlet_id], references: [id], onDelete: Cascade)

  @@index([outlet_id])
  @@index([date])
  @@index([voucher_number])
  @@map("expense_vouchers")
}

model ExpenseItem {
  id          Int            @id @default(autoincrement())
  voucher_id  Int
  category    String?        @default("General")
  amount      Float
  description String?
  voucher     ExpenseVoucher @relation(fields: [voucher_id], references: [id], onDelete: Cascade)

  @@index([voucher_id])
  @@map("expense_items")
}

model Vendor {
  id         Int              @id @default(autoincrement())
  outlet_id  Int
  name       String
  phone      String?
  email      String?
  address    String?
  balance    Float            @default(0)
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  payments   VendorPayment[]
  purchases  VendorPurchase[]
  returns    VendorPurchaseReturn[]
  outlet     Outlet           @relation(fields: [outlet_id], references: [id], onDelete: Cascade)

  @@index([outlet_id])
  @@index([name])
  @@map("vendors")
}

model VendorPurchase {
  id             Int                  @id @default(autoincrement())
  outlet_id      Int
  invoice_number String               @unique
  vendor_name    String
  notes          String?              @db.Text
  total_amount   Float                @default(0)
  paid_amount    Float                @default(0)
  balance        Float                @default(0)
  status         String               @default("Unpaid")
  purchase_date  DateTime             @default(now())
  created_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt
  due_date       DateTime?
  vendor_id      Int?
  payments       VendorPayment[]
  items          VendorPurchaseItem[]
  edit_histories VendorPurchaseEditHistory[]
  outlet         Outlet               @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  vendor         Vendor?              @relation(fields: [vendor_id], references: [id])
  returns        VendorPurchaseReturn[]

  @@index([outlet_id])
  @@index([vendor_id])
  @@index([vendor_name])
  @@index([status])
  @@index([created_at])
  @@map("vendor_purchases")
}

model VendorPurchaseEditHistory {
  id              Int            @id @default(autoincrement())
  purchase_id     Int
  edited_by_id    Int?
  edited_at       DateTime       @default(now())
  previous_data   Json
  new_data        Json
  changes_summary String?        @db.Text
  purchase        VendorPurchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  user            User?          @relation("vendor_purchase_edits", fields: [edited_by_id], references: [id])

  @@index([purchase_id])
  @@index([edited_by_id])
  @@map("vendor_purchase_edit_histories")
}

model VendorPurchaseItem {
  id            Int            @id @default(autoincrement())
  purchase_id   Int
  product_name  String
  category      String?
  color_variant String?
  imei_serial   String?
  quantity      Int            @default(1)
  unit_price    Float
  total_price   Float
  purchase      VendorPurchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)

  @@index([purchase_id])
  @@map("vendor_purchase_items")
}

model VendorPurchaseReturn {
  id              Int                      @id @default(autoincrement())
  outlet_id       Int
  return_number   String                   @unique
  purchase_id     Int?
  vendor_id       Int
  vendor_name     String
  return_date     DateTime                 @default(now())
  total_amount    Float                    @default(0)
  notes           String?                  @db.Text
  created_at      DateTime                 @default(now())
  updated_at      DateTime                 @updatedAt

  outlet          Outlet                   @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  purchase        VendorPurchase?          @relation(fields: [purchase_id], references: [id])
  vendor          Vendor                   @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
  items           VendorPurchaseReturnItem[]

  @@index([outlet_id])
  @@index([vendor_id])
  @@index([purchase_id])
  @@map("vendor_purchase_returns")
}

model VendorPurchaseReturnItem {
  id                Int                  @id @default(autoincrement())
  return_id         Int
  purchase_item_id  Int?
  product_name      String
  category          String?
  color_variant     String?
  imei_serial       String?
  quantity          Int
  unit_price        Float
  total_price       Float
  reason            String?              @db.Text

  return            VendorPurchaseReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)

  @@index([return_id])
  @@map("vendor_purchase_return_items")
}

model VendorPayment {
  id             Int            @id @default(autoincrement())
  outlet_id      Int
  purchase_id    Int
  vendor_name    String
  amount         Float
  payment_method String?        @default("Cash")
  notes          String?        @db.Text
  created_at     DateTime       @default(now())
  vendor_id      Int?
  outlet         Outlet         @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  purchase       VendorPurchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  vendor         Vendor?        @relation(fields: [vendor_id], references: [id])

  @@index([outlet_id])
  @@index([purchase_id])
  @@index([vendor_id])
  @@index([vendor_name])
  @@index([created_at])
  @@map("vendor_payments")
}

model OutletInventory {
  id                Int             @id @default(autoincrement())
  outlet_id         Int
  product_name      String
  category          String?
  imei_serial       String?
  purchase_price    Float
  installment_price Float
  status            String          @default("In Stock")
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  color_variant     String?
  quantity          Int             @default(1)
  installment_plans Json?
  sale_price        Float?          // API recommended sale price (from qistmarket.pk)
  api_product_name  String?         // Matched API product name for future sync
  outlet            Outlet          @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  stockTransfers    StockTransfer[]

  @@index([outlet_id])
  @@index([status])
  @@index([api_product_name])
  @@map("outlet_inventories")
}

model StockTransfer {
  id                   Int             @id @default(autoincrement())
  from_type            String
  from_id              Int
  to_type              String
  to_id                Int
  inventory_id         Int
  created_at           DateTime        @default(now())
  quantity_transferred Int             @default(1)
  status               String          @default("pending")
  updated_at           DateTime        @updatedAt @default(now())
  cash_in_hands        CashInHand[]
  inventory            OutletInventory @relation(fields: [inventory_id], references: [id], onDelete: Cascade)

  @@index([inventory_id])
  @@index([created_at])
  @@map("stock_transfers")
}

model Verification {
  id                      Int                       @id @default(autoincrement())
  order_id                Int                       @unique
  verification_officer_id Int
  status                  String                    @default("in_progress")
  start_time              DateTime
  end_time                DateTime?
  created_at              DateTime                  @default(now())
  updated_at              DateTime                  @updatedAt
  home_location_required  Boolean                   @default(false)
  home_location_verified  Boolean                   @default(false)
  verification_feedback   String?                   @db.Text
  grantors                GrantorVerification[]
  locations               LocationTracking[]
  nextOfKin               NextOfKinVerification?
  purchaser               PurchaserVerification?
  active_user             User?                     @relation("active_verification")
  order                   Order                     @relation("OrderVerification", fields: [order_id], references: [id], onDelete: Cascade)
  verification_officer    User                      @relation("verification_officer", fields: [verification_officer_id], references: [id])
  documents               VerificationDocument[]
  verification_locations  VerificationLocation[]
  reviews                 VerificationReview[]
  edit_history            VerificationEditHistory[] @relation("verification_edits")

  @@index([verification_officer_id])
}

model VerificationReview {
  id              Int          @id @default(autoincrement())
  verification_id Int
  reviewer_id     Int
  approved        Boolean
  remarks         String?      @db.Text
  created_at      DateTime     @default(now())
  reviewer        User         @relation("verification_reviewer", fields: [reviewer_id], references: [id])
  verification    Verification @relation(fields: [verification_id], references: [id], onDelete: Cascade)

  @@index([verification_id])
  @@index([reviewer_id])
}

model PurchaserVerification {
  id                       Int             @id @default(autoincrement())
  verification_id          Int             @unique
  name                     String
  father_husband_name      String
  present_address          String
  permanent_address        String
  utility_bill_url         String?
  cnic_number              String
  cnic_front_url           String?
  cnic_back_url            String?
  telephone_number         String
  employer_name            String
  employer_address         String
  designation              String
  official_number          String?
  service_card_url         String?
  years_in_company         String?
  gross_salary             String?
  signature_url            String?
  nearest_location         String
  is_verified              Boolean         @default(false)
  business_address         String?
  business_name            String?
  employment_type          EmploymentType? @default(EMPLOYED)
  established_since        String?
  job_type                 String?
  net_income               String?
  permanent_area           String?
  permanent_block          String?
  permanent_house_no       String?
  permanent_period_of_stay String?
  permanent_street         String?
  permanent_zone           String?
  present_area             String?
  present_block            String?
  present_house_no         String?
  present_period_of_stay   String?
  present_street           String?
  present_zone             String?
  is_blacklisted           Boolean         @default(false)
  verification             Verification    @relation(fields: [verification_id], references: [id], onDelete: Cascade)

  @@index([verification_id])
}

model GrantorVerification {
  id                       Int             @id @default(autoincrement())
  verification_id          Int
  grantor_number           Int
  name                     String
  father_husband_name      String
  present_address          String
  permanent_address        String
  utility_bill_url         String?
  cnic_number              String
  cnic_front_url           String?
  cnic_back_url            String?
  telephone_number         String
  designation              String
  official_number          String?
  service_card_url         String?
  office_address           String
  company_name             String?
  years_in_company         String?
  monthly_income           String?
  full_residential_address String
  relationship             String
  signature_url            String?
  nearest_location         String
  is_verified              Boolean         @default(false)
  business_address         String?
  business_name            String?
  employment_type          EmploymentType? @default(EMPLOYED)
  established_since        String?
  job_type                 String?
  net_income               String?
  permanent_area           String?
  permanent_block          String?
  permanent_house_no       String?
  permanent_period_of_stay String?
  permanent_street         String?
  permanent_zone           String?
  present_area             String?
  present_block            String?
  present_house_no         String?
  present_period_of_stay   String?
  present_street           String?
  present_zone             String?
  is_blacklisted           Boolean         @default(false)
  verification             Verification    @relation(fields: [verification_id], references: [id], onDelete: Cascade)

  @@unique([verification_id, grantor_number])
  @@index([verification_id])
}

model NextOfKinVerification {
  id              Int          @id @default(autoincrement())
  verification_id Int          @unique
  name            String
  cnic_number     String
  relation        String
  phone_number    String
  verification    Verification @relation(fields: [verification_id], references: [id], onDelete: Cascade)

  @@index([verification_id])
}

model LocationTracking {
  id              Int          @id @default(autoincrement())
  verification_id Int
  latitude        Float
  longitude       Float
  accuracy        Float?
  label           String
  timestamp       DateTime     @default(now())
  verification    Verification @relation(fields: [verification_id], references: [id], onDelete: Cascade)

  @@index([verification_id])
}

model VerificationLocation {
  id              Int                         @id @default(autoincrement())
  verification_id Int
  location_type   String
  latitude        Float?
  longitude       Float?
  address         String?
  label           String
  person_type     String?
  person_id       Int?
  created_at      DateTime                    @default(now())
  verification    Verification                @relation(fields: [verification_id], references: [id])
  photos          VerificationLocationPhoto[]

  @@index([verification_id])
  @@index([person_type, person_id])
}

model VerificationLocationPhoto {
  id                       Int                  @id @default(autoincrement())
  verification_location_id Int
  file_url                 String
  uploaded_at              DateTime             @default(now())
  verification_location    VerificationLocation @relation(fields: [verification_location_id], references: [id])

  @@index([verification_location_id])
}

model VerificationDocument {
  id              Int          @id @default(autoincrement())
  verification_id Int
  document_type   String
  person_type     String
  person_id       Int?
  file_url        String
  label           String?
  uploaded_at     DateTime     @default(now())
  verification    Verification @relation(fields: [verification_id], references: [id], onDelete: Cascade)

  @@index([verification_id])
  @@index([person_type, person_id])
}

model Delivery {
  id                 Int                @id @default(autoincrement())
  order_id           Int                @unique
  delivery_agent_id  Int
  status             String             @default("pending")
  start_time         DateTime?
  end_time           DateTime?
  feedback           String?
  verified           Boolean            @default(false)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  product_imei       String?            @db.VarChar(100)
  selected_plan      Json?
  self_pickup        Boolean            @default(false)
  delivery_agent     User               @relation("delivery_agent", fields: [delivery_agent_id], references: [id])
  order              Order              @relation("OrderDelivery", fields: [order_id], references: [id], onDelete: Cascade)
  uploads            DeliveryUpload[]
  installment_ledger InstallmentLedger?
  consumerNumbers    ConsumerNumber[]

  @@index([delivery_agent_id])
}

model DeliveryUpload {
  id          Int      @id @default(autoincrement())
  delivery_id Int
  upload_type String
  file_url    String?
  link        String?
  tag         String?
  uploaded_at DateTime @default(now())
  delivery    Delivery @relation(fields: [delivery_id], references: [id], onDelete: Cascade)

  @@index([delivery_id])
}

model CashInHand {
  id                Int            @id @default(autoincrement())
  officer_id        Int
  order_id          Int
  amount            Float
  status            String         @default("pending")
  payment_method    String?
  outlet_id         Int?
  otp               String?
  customer_name     String?
  product_name      String?
  imei_serial       String?
  color_variant     String?
  stock_transfer_id Int?

  // New fields for partial payment support
  cash_type         String?        @default("Advance amount payment")
  submitted_amount  Float          @default(0)

  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  officer           User           @relation("OfficerCashInHand", fields: [officer_id], references: [id])
  order             Order          @relation("OrderCashInHand", fields: [order_id], references: [id])
  outlet            Outlet?        @relation("OutletCashInHand", fields: [outlet_id], references: [id])
  stock_transfer    StockTransfer? @relation(fields: [stock_transfer_id], references: [id])
  submission_history CashSubmissionHistory[]

  @@index([officer_id])
  @@index([order_id])
  @@index([outlet_id])
  @@index([stock_transfer_id])
  @@index([created_at])
  @@index([status])
  @@map("cash_in_hand")
}

model CashSubmissionHistory {
  id               Int        @id @default(autoincrement())
  cash_in_hand_id  Int
  amount_submitted Float
  submission_date  DateTime   @default(now())
  status           String     @default("pending")
  otp              String?
  submission_ref   String?    // Added to group split submissions
  outlet_id        Int?
  cash_in_hand     CashInHand @relation(fields: [cash_in_hand_id], references: [id], onDelete: Cascade)

  @@index([cash_in_hand_id])
  @@index([otp])
  @@index([submission_ref])
  @@index([outlet_id])
  @@map("cash_submission_history")
}

model ReturnExchange {
  id                  Int       @id @default(autoincrement())
  order_id            Int
  delivery_officer_id Int?
  outlet_id           Int
  type                String
  status              String    @default("pending")
  otp                 String?
  imei_returned       String?
  created_at          DateTime  @default(now())
  verified_at         DateTime?
  initiated_by        String    @default("DeliveryOfficer")
  is_cash_refund      Boolean   @default(false)
  is_used             Boolean   @default(false)
  refund_amount       Float     @default(0)
  product_name        String?
  selected_plan       Json?
  delivery_officer    User?     @relation("OfficerReturnExchange", fields: [delivery_officer_id], references: [id])
  order               Order     @relation("OrderReturnExchange", fields: [order_id], references: [id])
  outlet              Outlet    @relation("OutletReturnExchange", fields: [outlet_id], references: [id])

  @@index([order_id])
  @@index([delivery_officer_id])
  @@index([outlet_id])
  @@map("return_exchanges")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String
  relatedId Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}

model OfficerSession {
  id               Int       @id @default(autoincrement())
  officer_id       Int
  start_time       DateTime
  end_time         DateTime?
  duration_minutes Int?
  created_at       DateTime  @default(now())
  officer          User      @relation(fields: [officer_id], references: [id], onDelete: Cascade)

  @@index([officer_id])
  @@index([start_time])
  @@index([officer_id, start_time])
}

model OrderPayment {
  id            Int       @id @default(autoincrement())
  order_id      Int
  paymentType   String
  monthNumber   Int?
  amount        Float
  paidAt        DateTime  @default(now())
  paymentMethod String?
  collectedBy_id Int?
  collectedBy   User?     @relation("PaymentCollector", fields: [collectedBy_id], references: [id])
  created_at    DateTime  @default(now())
  is_submitted  Boolean   @default(false)
  submitted_at  DateTime?
  feedback      String?
  order         Order     @relation(fields: [order_id], references: [id])

  @@index([order_id])
  @@index([order_id, paymentType])
}

model OfficerAreaAssignment {
  id        Int      @id @default(autoincrement())
  user_id   Int
  zone      String
  area      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("OfficerAssignments", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, zone, area])
  @@index([user_id])
  @@index([zone, area])
}

model OrderProductHistory {
  id                 Int      @id @default(autoincrement())
  order_id           Int
  previous_product   String
  current_product    String
  changed_at         DateTime @default(now())
  changed_by_user_id Int
  changed_by         User     @relation("ProductChangeHistory", fields: [changed_by_user_id], references: [id])
  order              Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([changed_by_user_id])
}

model City {
  id     Int    @id @default(autoincrement())
  name   String @unique
  status String @default("active")
  zones  Zone[]

  @@map("cities")
}

model Zone {
  id      Int    @id @default(autoincrement())
  name    String
  city_id Int
  status  String @default("active")
  areas   Area[]
  city    City   @relation(fields: [city_id], references: [id], onDelete: Cascade)

  @@unique([name, city_id])
  @@index([city_id], map: "zones_city_id_fkey")
  @@map("zones")
}

model SmartPayQr {
  id              Int      @id @default(autoincrement())
  order_id        Int
  month_number    Int
  qr_string       String   @db.Text
  qr_image_base64 String   @db.LongText
  amount          Float
  created_at      DateTime @default(now())
  order           Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@unique([order_id, month_number])
  @@index([order_id])
  @@map("smart_pay_qrs")
}

model Area {
  id      Int    @id @default(autoincrement())
  name    String
  zone_id Int
  status  String @default("active")
  zone    Zone   @relation(fields: [zone_id], references: [id], onDelete: Cascade)

  @@unique([name, zone_id])
  @@index([zone_id], map: "areas_zone_id_fkey")
  @@map("areas")
}

model VerificationEditHistory {
  id              Int          @id @default(autoincrement())
  verification_id Int
  entity_type     String
  entity_id       Int
  field_name      String
  old_value       String?      @db.Text
  new_value       String?      @db.Text
  edited_by_id    Int
  edited_by_name  String
  edited_at       DateTime     @default(now())
  edited_by       User         @relation("user_edits", fields: [edited_by_id], references: [id])
  verification    Verification @relation("verification_edits", fields: [verification_id], references: [id], onDelete: Cascade)

  @@index([verification_id])
  @@index([entity_type, entity_id])
  @@index([edited_by_id])
  @@map("verification_edit_history")
}

model InstallmentLedger {
  id          Int      @id @default(autoincrement())
  order_id    Int      @unique
  delivery_id Int      @unique
  token       String   @unique @db.VarChar(512)
  ledger_rows Json
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  short_id    String?  @unique @db.VarChar(20)
  delivery    Delivery @relation(fields: [delivery_id], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  consumer_numbers ConsumerNumber[]

  @@index([token])
  @@index([short_id])
  @@map("installment_ledgers")
}

model RecoveryVisit {
  id                Int                  @id @default(autoincrement())
  order_id          Int
  officer_id        Int
  latitude          Float?
  longitude         Float?
  visit_time        DateTime             @default(now())
  customer_feedback String?              @db.Text
  visit_notes       String?              @db.Text
  payment_collected Boolean              @default(false)
  amount_collected  Float?
  fuel_charges      Float?               @default(0)
  created_at        DateTime             @default(now())
  photos            RecoveryVisitPhoto[]
  officer           User                 @relation("OfficerRecoveryVisit", fields: [officer_id], references: [id])
  order             Order                @relation("OrderRecoveryVisit", fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([officer_id])
  @@map("recovery_visits")
}

model RecoveryVisitPhoto {
  id                Int           @id @default(autoincrement())
  recovery_visit_id Int
  file_url          String
  photo_type        String?
  uploaded_at       DateTime      @default(now())
  recovery_visit    RecoveryVisit @relation(fields: [recovery_visit_id], references: [id], onDelete: Cascade)

  @@index([recovery_visit_id])
}

model SecurityLog {
  id          Int      @id @default(autoincrement())
  outlet_id   Int
  user_id     Int
  user_name   String
  action      String
  details     String   @db.Text
  target_id   Int?
  target_type String?
  created_at  DateTime @default(now())
  outlet      Outlet   @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id])

  @@index([outlet_id])
  @@index([user_id])
  @@index([created_at])
  @@map("security_logs")
}

model OtpLog {
  id         Int      @id @default(autoincrement())
  user_id    Int
  action     String
  message    String   @db.Text
  otp        String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([created_at])
  @@map("otp_logs")
}

model AppVersion {
  id            Int      @id @default(autoincrement())
  version       String   @unique
  force_update  Boolean  @default(false)
  message       String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("app_versions")
}

enum EmploymentType {
  EMPLOYED
  SELF_EMPLOYED
}

model Customer {
  id               Int      @id @default(autoincrement())
  cnic             String?  @unique
  mobile           String   @unique
  name             String
  is_blacklisted   Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  orders           Order[]

  @@map("customers")
}

model CsrRanking {
  id                Int      @id @default(autoincrement())
  csr_id            Int
  period            String   // "today", "week", "month"
  month             Int?     // 1-12
  year              Int?
  unique_customers  Int      @default(0)
  delivered_customers Int    @default(0)
  completed_customers Int    @default(0)
  repeat_customers    Int    @default(0)
  cancelled_customers Int    @default(0)
  expired_customers   Int    @default(0)
  total_sales       Float    @default(0)
  score             Float    @default(0)
  rank              Int      @default(0)
  trend             Int      @default(0) // -1, 0, 1
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [csr_id], references: [id])

  @@unique([csr_id, period, month, year])
  @@map("csr_rankings")
}

model ConsumerNumber {
  id              Int       @id @default(autoincrement())
  consumer_number String    @unique
  ledger_id       Int
  delivery_id     Int
  customer_name   String
  mobile_number   String
  imei_serial     String?
  amount_due      Decimal   @db.Decimal(10, 2)
  billing_month   String    @db.VarChar(4) // format YYMM
  due_date        DateTime
  bill_status     String    @default("U") @db.VarChar(1) // U=Unpaid, P=Paid, B=Blocked
  amount_paid     Decimal?  @db.Decimal(10, 2)
  date_paid       DateTime?
  tran_auth_id    String?
  bank_mnemonic   String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  ledger   InstallmentLedger @relation(fields: [ledger_id], references: [id])
  delivery Delivery          @relation(fields: [delivery_id], references: [id])

  @@index([consumer_number])
  @@map("consumer_numbers")
}

model TpsPaymentLog {
  id                        Int      @id @default(autoincrement())
  consumer_number           String
  tran_auth_id              String
  transaction_amount_raw    String
  transaction_amount_parsed Decimal  @db.Decimal(10, 2)
  tran_date                 String
  tran_time                 String
  bank_mnemonic             String
  reserved                  String?
  response_code_sent        String
  is_duplicate              Boolean  @default(false)
  created_at                DateTime @default(now())

  @@index([consumer_number, tran_auth_id, tran_date, tran_time])
  @@map("tps_payment_logs")
}
